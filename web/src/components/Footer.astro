---
import { type Lang, defaultLang, useTranslations, getLocalizedPath } from '../i18n'

interface Props {
  lang?: Lang
}

const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)
const year = new Date().getFullYear()
const homePath = getLocalizedPath('', lang)

const links = {
  product: [
    { label: t.footer.links.features, href: `${homePath}#features` },
    { label: t.footer.links.pricing, href: `${homePath}#pricing` },
    { label: t.footer.links.faq, href: `${homePath}#faq` },
    { label: t.header.signIn, href: 'https://app.mrrlytics.com/login' },
    { label: t.header.getStarted, href: 'https://app.mrrlytics.com/register' },
  ],
  company: [
    { label: t.footer.links.about, href: getLocalizedPath('about', lang) },
    { label: t.footer.links.contact, href: getLocalizedPath('contact', lang) },
  ],
  legal: [
    { label: t.footer.links.privacy, href: getLocalizedPath('privacy', lang) },
    { label: t.footer.links.terms, href: getLocalizedPath('terms', lang) },
  ],
}
---

<footer class="glass-section py-16">
  <div class="wrap">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-12 mb-16">
      <!-- Brand -->
      <div class="col-span-2">
        <a href={homePath} class="flex items-center mb-5">
          <img src="/logo-white.svg" alt="MRRlytics" class="h-[30px] w-auto" />
        </a>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-xs">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t.footer.product}</h4>
        <ul class="space-y-3">
          {links.product.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t.footer.company}</h4>
        <ul class="space-y-3">
          {links.company.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t.footer.legal}</h4>
        <ul class="space-y-3">
          {links.legal.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="line-dotted mb-8"></div>
    <p class="text-sm text-[var(--color-text-muted)] text-center">&copy; {year} MRRlytics. {t.footer.copyright}</p>
  </div>
</footer>
