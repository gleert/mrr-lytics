---
import { type Lang, defaultLang, useTranslations } from '../i18n'

interface Props {
  lang?: Lang
}

const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)
---

<section id="faq" class="glass-section py-32 md:py-40">
  <div class="wrap relative">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: Header -->
      <div>
        <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-6 lg:sticky lg:top-32">
          {t.faq.title}
        </h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          {t.faq.subtitle}{' '}
          <a href="mailto:support@mrrlytics.com" class="text-[var(--color-primary-400)] hover:underline">
            {t.faq.contactTeam}
          </a>.
        </p>
      </div>

      <!-- Right: Questions -->
      <div class="space-y-4">
        {t.faq.items.map((faq, i) => (
          <details class="glass-card group">
            <summary class="flex items-center justify-between cursor-pointer list-none p-6">
              <span class="text-lg font-medium pr-8 group-hover:text-[var(--color-primary-400)] transition-colors">
                {faq.question}
              </span>
              <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-[var(--color-text-muted)]">
                <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </span>
            </summary>
            <p class="px-6 pb-6 text-[var(--color-text-muted)] leading-relaxed pr-12">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
