---
import { type Lang, defaultLang, useTranslations } from '../i18n'

interface Props {
  lang?: Lang
}

const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)
---

<section class="relative pt-40 pb-32 md:pt-48 md:pb-40">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[var(--color-primary-500)] opacity-[0.04] blur-[150px]"></div>
  </div>

  <div class="wrap relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Text content -->
      <div class="text-center lg:text-left">
        <!-- Main title -->
        <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-6">
          {t.hero.title}<br/>
          <span class="text-gradient">{t.hero.titleHighlight}</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-[var(--color-text-muted)] max-w-xl mb-10 leading-relaxed">
          {t.hero.subtitle}
        </p>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4">
          <a href="https://app.mrrlytics.com/register" class="btn btn-primary">
            <span class="dot"></span>
            <span>{t.hero.ctaPrimary}</span>
          </a>
          <a href="https://app.mrrlytics.com/login" class="btn btn-secondary">
            {t.header.signIn}
          </a>
        </div>
      </div>

      <!-- Right: Video -->
      <div class="video-container glass-card aspect-video overflow-hidden">
        <video 
          class="w-full h-full object-cover"
          autoplay 
          muted 
          loop 
          playsinline
          poster="/video-poster.jpg"
        >
          <source src="https://cdn.pixabay.com/video/2022/07/16/124333-730771399_large.mp4" type="video/mp4" />
        </video>
        
        <!-- Decorative corners -->
        <div class="absolute top-4 left-4 w-8 h-8 border-l-2 border-t-2 border-[var(--color-border-dashed)] rounded-tl-lg pointer-events-none"></div>
        <div class="absolute top-4 right-4 w-8 h-8 border-r-2 border-t-2 border-[var(--color-border-dashed)] rounded-tr-lg pointer-events-none"></div>
        <div class="absolute bottom-4 left-4 w-8 h-8 border-l-2 border-b-2 border-[var(--color-border-dashed)] rounded-bl-lg pointer-events-none"></div>
        <div class="absolute bottom-4 right-4 w-8 h-8 border-r-2 border-b-2 border-[var(--color-border-dashed)] rounded-br-lg pointer-events-none"></div>
      </div>
    </div>

  </div>
</section>
