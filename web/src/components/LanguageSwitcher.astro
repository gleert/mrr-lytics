---
import { type Lang, languages, getLocalizedPath } from '../i18n'

interface Props {
  lang: Lang
}

const { lang } = Astro.props

const currentPath = Astro.url.pathname
let basePath = currentPath

for (const l of Object.keys(languages) as Lang[]) {
  if (currentPath.startsWith(`/${l}/`)) {
    basePath = currentPath.slice(l.length + 1)
    break
  } else if (currentPath === `/${l}`) {
    basePath = ''
    break
  }
}
---

<div class="lang-switcher relative">
  <button
    type="button"
    class="lang-toggle flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
  >
    <span class="uppercase text-xs font-medium">{lang}</span>
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div class="lang-menu absolute right-0 mt-3 hidden min-w-[100px] py-2 bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-lg shadow-xl z-50">
    {(Object.entries(languages) as [Lang, string][]).map(([code, name]) => (
      <a
        href={getLocalizedPath(basePath, code)}
        class:list={[
          "block px-4 py-2 text-sm transition-colors",
          code === lang
            ? "text-[var(--color-primary-400)]"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-border)]"
        ]}
      >
        {name}
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('.lang-switcher').forEach(switcher => {
    const toggle = switcher.querySelector('.lang-toggle')
    const menu = switcher.querySelector('.lang-menu')

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation()
      menu?.classList.toggle('hidden')
    })

    document.addEventListener('click', (e) => {
      if (!switcher.contains(e.target as Node)) {
        menu?.classList.add('hidden')
      }
    })
  })
</script>
