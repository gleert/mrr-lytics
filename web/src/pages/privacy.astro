---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { useTranslations } from '../i18n'

const lang = 'en'
const t = useTranslations(lang)
---

<Layout title={t.privacy.meta.title} description={t.privacy.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <section class="pt-40 pb-20 md:pt-48 md:pb-28">
      <div class="wrap">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-4">
            {t.privacy.title}
          </h1>
          <p class="text-[var(--color-text-muted)] mb-12">{t.privacy.lastUpdated}</p>

          <div class="space-y-12">
            {t.privacy.sections.map((section, index) => (
              <div>
                <h2 class="text-xl font-semibold mb-4">{section.title}</h2>
                <div class="text-[var(--color-text-muted)] leading-relaxed whitespace-pre-line">
                  {section.content}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
