---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { useTranslations } from '../i18n'

const lang = 'en'
const t = useTranslations(lang)
---

<Layout title={t.about.meta.title} description={t.about.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <!-- Hero -->
    <section class="pt-40 pb-20 md:pt-48 md:pb-28">
      <div class="wrap">
        <div class="max-w-3xl">
          <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-6">
            {t.about.hero.title}<br/>
            <span class="text-gradient">{t.about.hero.titleHighlight}</span>
          </h1>
          <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed">
            {t.about.hero.subtitle}
          </p>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-20 md:py-28">
      <div class="wrap">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="glass-card p-10 md:p-14">
            <h2 class="text-2xl md:text-3xl font-bold mb-6">{t.about.mission.title}</h2>
            <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
              {t.about.mission.description}
            </p>
          </div>
          <div>
            <h2 class="text-2xl md:text-3xl font-bold mb-8">{t.about.story.title}</h2>
            <div class="space-y-6">
              {t.about.story.paragraphs.map((paragraph) => (
                <p class="text-[var(--color-text-muted)] leading-relaxed">
                  {paragraph}
                </p>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="glass-section py-20 md:py-28">
      <div class="wrap relative">
        <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold mb-16">{t.about.values.title}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {t.about.values.items.map((value, index) => (
            <div class="glass-card p-8 md:p-10 group transition-all duration-300">
              <span class="text-xs text-[var(--color-text-muted)] font-mono">0{index + 1}</span>
              <h3 class="text-xl font-semibold mt-4 mb-3 group-hover:text-[var(--color-primary-400)] transition-colors">
                {value.title}
              </h3>
              <p class="text-[var(--color-text-muted)] leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="glass-section py-20 md:py-28">
      <div class="wrap relative">
        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold mb-4">{t.about.cta.title}</h2>
          <p class="text-lg text-[var(--color-text-muted)] mb-10">{t.about.cta.subtitle}</p>
          <a href="https://app.mrrlytics.com/register" class="btn btn-primary">
            <span class="dot"></span>
            <span>{t.about.cta.button}</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
