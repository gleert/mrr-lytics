---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { useTranslations, getLocalizedPath } from '../i18n'

// Detect lang from the URL (best effort, defaults to EN)
const lang = Astro.url.pathname.startsWith('/es') ? 'es' : 'en'
const t = useTranslations(lang)
---

<Layout
  title={lang === 'es' ? 'Página no encontrada - MRRlytics' : 'Page Not Found - MRRlytics'}
  description={lang === 'es' ? 'La página que buscas no existe.' : 'The page you are looking for does not exist.'}
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-4 pt-32 pb-20">
      <div class="max-w-lg mx-auto">
        <!-- 404 number -->
        <p class="text-[clamp(6rem,20vw,10rem)] font-bold leading-none tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-[var(--color-primary-400)] to-[var(--color-primary-700)] select-none mb-4">
          404
        </p>

        <h1 class="text-2xl md:text-3xl font-bold mb-4">
          {lang === 'es' ? 'Página no encontrada' : 'Page not found'}
        </h1>

        <p class="text-[var(--color-text-muted)] leading-relaxed mb-8">
          {lang === 'es'
            ? 'La página que estás buscando no existe o ha sido movida.'
            : 'The page you are looking for does not exist or has been moved.'}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={getLocalizedPath('', lang)}
            class="btn btn-primary"
          >
            {lang === 'es' ? 'Ir al inicio' : 'Go home'}
          </a>
          <a
            href={getLocalizedPath('docs', lang)}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary-500)] transition-colors"
          >
            {lang === 'es' ? 'Ver documentación' : 'View docs'}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
