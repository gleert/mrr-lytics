---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/Header.astro'
import Footer from '../../../components/Footer.astro'
import DocsLayout from '../../../components/DocsLayout.astro'
import { useTranslations } from '../../../i18n'

const lang = 'es'
const t = useTranslations(lang)
---

<Layout title={t.docs.whmcsModule.meta.title} description={t.docs.whmcsModule.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <section class="pt-40 pb-12 md:pt-48 md:pb-16">
      <div class="wrap">
        <h1 class="text-[clamp(2rem,5vw,3rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-4">
          {t.docs.whmcsModule.title}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
          {t.docs.whmcsModule.subtitle}
        </p>
      </div>
    </section>

    <section class="pb-20 md:pb-28">
      <DocsLayout lang={lang} activeSlug="whmcs-module">
        <div class="space-y-12">
          {t.docs.whmcsModule.sections.map((section) => (
            <div>
              <h2 class="text-xl font-semibold mb-4">{section.title}</h2>
              <div class="text-[var(--color-text-muted)] leading-relaxed whitespace-pre-line">
                {section.content}
              </div>
            </div>
          ))}
        </div>
      </DocsLayout>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
