---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { useTranslations } from '../../i18n'

const lang = 'es'
const t = useTranslations(lang)

const contactInfo = [
  { ...t.contact.info.email, icon: 'email' },
  { ...t.contact.info.sales, icon: 'sales' },
  { ...t.contact.info.support, icon: 'support' },
]
---

<Layout title={t.contact.meta.title} description={t.contact.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <!-- Hero -->
    <section class="pt-40 pb-16 md:pt-48 md:pb-20">
      <div class="wrap">
        <div class="max-w-2xl mx-auto text-center">
          <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-6">
            {t.contact.hero.title}
          </h1>
          <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed">
            {t.contact.hero.subtitle}
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form + Info -->
    <section class="pb-20 md:pb-28">
      <div class="wrap">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
          <!-- Form -->
          <div class="lg:col-span-3">
            <form id="contact-form" class="glass-card p-8 md:p-10 space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium mb-2">{t.contact.form.name}</label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required
                    placeholder={t.contact.form.namePlaceholder}
                    class="form-input"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium mb-2">{t.contact.form.email}</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required
                    placeholder={t.contact.form.emailPlaceholder}
                    class="form-input"
                  />
                </div>
              </div>
              
              <div>
                <label for="subject" class="block text-sm font-medium mb-2">{t.contact.form.subject}</label>
                <input 
                  type="text" 
                  id="subject" 
                  name="subject" 
                  required
                  placeholder={t.contact.form.subjectPlaceholder}
                  class="form-input"
                />
              </div>
              
              <div>
                <label for="message" class="block text-sm font-medium mb-2">{t.contact.form.message}</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="6" 
                  required
                  placeholder={t.contact.form.messagePlaceholder}
                  class="form-input resize-none"
                ></textarea>
              </div>

              <div id="form-success" class="hidden flex items-center gap-3 p-4 rounded-xl bg-green-500/10 border border-green-500/20 text-green-400 text-sm">
                <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{t.contact.form.successMessage}</span>
              </div>
              <div id="form-error" class="hidden flex items-center gap-3 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
                <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                </svg>
                <span id="form-error-text">{t.contact.form.errorMessage}</span>
              </div>
              
              <button type="submit" id="submit-btn" class="btn btn-primary w-full md:w-auto justify-center">
                <span class="dot"></span>
                <span id="submit-text">{t.contact.form.submit}</span>
              </button>
            </form>
          </div>

          <!-- Contact Info -->
          <div class="lg:col-span-2 space-y-8">
            <div>
              <h2 class="text-xl font-semibold mb-6">{t.contact.info.title}</h2>
              <div class="space-y-6">
                {contactInfo.map((info) => (
                  <a href={`mailto:${info.value}`} class="glass-card p-5 flex items-start gap-4 group transition-all duration-300 block">
                    <div class="w-10 h-10 rounded-lg bg-[var(--color-primary-500)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary-500)]/20 transition-colors">
                      {info.icon === 'email' && (
                        <svg class="w-5 h-5 text-[var(--color-primary-400)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                        </svg>
                      )}
                      {info.icon === 'sales' && (
                        <svg class="w-5 h-5 text-[var(--color-primary-400)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                        </svg>
                      )}
                      {info.icon === 'support' && (
                        <svg class="w-5 h-5 text-[var(--color-primary-400)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                        </svg>
                      )}
                    </div>
                    <div>
                      <p class="text-sm text-[var(--color-text-muted)]">{info.label}</p>
                      <p class="font-medium group-hover:text-[var(--color-primary-400)] transition-colors">{info.value}</p>
                      <p class="text-sm text-[var(--color-text-muted)] mt-1">{info.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <!-- Mini FAQ -->
            <div>
              <h2 class="text-xl font-semibold mb-6">{t.contact.faq.title}</h2>
              <div class="space-y-4">
                {t.contact.faq.items.map((item) => (
                  <div class="glass-card p-5">
                    <h3 class="font-medium mb-2">{item.question}</h3>
                    <p class="text-sm text-[var(--color-text-muted)]">{item.answer}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const submitText = document.getElementById('submit-text') as HTMLSpanElement
  const successEl = document.getElementById('form-success') as HTMLDivElement
  const errorEl = document.getElementById('form-error') as HTMLDivElement
  const errorText = document.getElementById('form-error-text') as HTMLSpanElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    successEl.classList.add('hidden')
    errorEl.classList.add('hidden')
    submitBtn.disabled = true
    submitText.textContent = '...'

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      subject: (form.elements.namedItem('subject') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
      lang: 'es',
    }

    try {
      const res = await fetch('https://api.mrrlytics.com/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      const json = await res.json()

      if (res.ok && json.success) {
        successEl.classList.remove('hidden')
        form.reset()
      } else {
        errorText.textContent = json.error || 'Algo salió mal. Por favor, inténtalo de nuevo.'
        errorEl.classList.remove('hidden')
      }
    } catch {
      errorText.textContent = 'Error de red. Por favor, verifica tu conexión e inténtalo de nuevo.'
      errorEl.classList.remove('hidden')
    } finally {
      submitBtn.disabled = false
      submitText.textContent = submitText.dataset.originalText || 'Enviar Mensaje'
    }
  })

  if (submitText) submitText.dataset.originalText = submitText.textContent || ''
</script>

<style>
  .form-input {
    width: 100%;
    padding: 12px 16px;
    background: rgba(17, 17, 20, 0.5);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
  }
</style>
