---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import DocsLayout from '../../components/DocsLayout.astro'
import { useTranslations } from '../../i18n'

const lang = 'en'
const t = useTranslations(lang)
---

<Layout title={t.docs.gettingStarted.meta.title} description={t.docs.gettingStarted.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <section class="pt-40 pb-12 md:pt-48 md:pb-16">
      <div class="wrap">
        <h1 class="text-[clamp(2rem,5vw,3rem)] font-bold leading-[1.1] tracking-[-0.02em] mb-4">
          {t.docs.gettingStarted.title}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
          {t.docs.gettingStarted.subtitle}
        </p>
      </div>
    </section>

    <section class="pb-20 md:pb-28">
      <DocsLayout lang={lang} activeSlug="getting-started">
        <div class="space-y-12">
          {t.docs.gettingStarted.steps.map((step) => (
            <div>
              <h2 class="text-xl font-semibold mb-4">{step.title}</h2>
              <div class="text-[var(--color-text-muted)] leading-relaxed whitespace-pre-line">
                {step.content}
              </div>
            </div>
          ))}

          <div class="glass-card p-8">
            <h2 class="text-xl font-semibold mb-4">{t.docs.gettingStarted.nextSteps.title}</h2>
            <ul class="space-y-3">
              {t.docs.gettingStarted.nextSteps.items.map((item) => (
                <li class="flex items-start gap-3 text-[var(--color-text-muted)]">
                  <span class="text-[var(--color-primary-400)] mt-1">&#10003;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </DocsLayout>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
